# Lumo 开发期配置示例。
# 复制为 .env.local（已 gitignore，仅本机生效）后按需修改：
#   cp .env.example .env.local

# OO 服务 endpoint 主域（其余子域如 llm./connector./console./api./hub./static. 全部由它派生）。
# 缺省 oomol.com。本地开发指向开发域名时改成 oomol.dev。
#
# 读取规则（见 vite.config.ts resolveOoEndpoint）：
#   - dev（npm run dev）与测试（vitest）经 loadEnv 读取本文件；
#   - build（npm run build）刻意【不读】本文件，始终缺省 oomol.com，确保对外分发的包不含开发域名；
#   - 两种模式都尊重显式的 LUMO_ENDPOINT 环境变量，故如需为某次构建指定（如内部联调包）：
#       LUMO_ENDPOINT=oomol.dev npm run build
LUMO_ENDPOINT=oomol.com

# oo 二进制覆盖（可选，进程环境变量）。dev 缺省用项目本地 .oo-bin/oo（postinstall 下载）；
# 若要指向自己编译/调试的 oo，启动时显式注入即可：
#   LUMO_OO_BIN=/abs/path/to/oo npm run dev
# LUMO_OO_BIN=

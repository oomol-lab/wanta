{
  "name": "lumo",
  "displayName": "Lumo",
  "version": "0.0.0",
  "private": true,
  "description": "Lumo — AI agent chat client for non-coding analysis and automation over OOMOL connectors.",
  "author": "OOMOL",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "node --experimental-strip-types ./scripts/download-electron.ts && node --experimental-strip-types ./scripts/download-oo.ts",
    "predev": "node --experimental-strip-types ./scripts/check-oo.ts",
    "dev": "vite",
    "build": "npm run build:app",
    "ts-check": "tsgo -p tsconfig.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "test": "vitest run",
    "build:app": "npm run ts-check && vite build",
    "prepare:binaries": "node --experimental-strip-types scripts/prepare-binaries.ts",
    "build:electron": "npm run build:app && npm run prepare:binaries && electron-builder --publish never",
    "build:mac": "npm run build:app && npm run prepare:binaries && electron-builder --mac --publish never",
    "build:win": "npm run build:app && npm run prepare:binaries && electron-builder --win --publish never",
    "build:linux": "npm run build:app && npm run prepare:binaries && electron-builder --linux --publish never"
  },
  "dependencies": {
    "@opencode-ai/sdk": "1.17.3",
    "electron-updater": "6.8.9"
  },
  "devDependencies": {
    "@electron-internal/extract-zip": "^1.0.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron/get": "^5.0.0",
    "@oomol/connection": "^0.2.28",
    "@oomol/connection-electron-adapter": "^0.2.12",
    "@opencode-ai/plugin": "1.17.3",
    "@shikijs/langs": "^4.2.0",
    "@shikijs/themes": "^4.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260514.1",
    "@vitejs/plugin-react": "^6.0.2",
    "ai": "^6.0.202",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^42.1.0",
    "electron-builder": "26.15.2",
    "lucide-react": "^1.16.0",
    "opencode-ai": "1.17.3",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "plist": "^5.0.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "use-stick-to-bottom": "^1.1.6",
    "vite": "^8.0.13",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
